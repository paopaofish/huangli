{
  "name": "Android Single File Env",
  // 直接引用微软官方的通用 Ubuntu 镜像
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  
  "features": {
    // 1. 自动安装 Java 17
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17",
      "jdkDistro": "ms"
    },
    // 2. 自动安装社区维护的 Android-SDK Feature（包含 sdkmanager、platform-tools 等）
    "ghcr.io/stuartleeks/devcontainer-features/android-sdk:0": {
      "packages": "platform-tools platforms;android-34 build-tools;34.0.0"
    }
  },

  // 关键：将 Android SDK 路径注入容器环境变量
  "containerEnv": {
    "ANDROID_HOME": "/usr/local/share/android-sdk",
    "ANDROID_SDK_ROOT": "/usr/local/share/android-sdk"
  },

  // 自动安装 VS Code 的 Android/Java 开发常用插件
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vscjava.vscode-gradle"
      ]
    }
  },

  // 允许容器使用宿主机的 USB 设备（用于真机调试，仅限 Linux 宿主机直接生效）
  "runArgs": [
    "--privileged",
    "-v", "/dev/bus/usb:/dev/bus/usb"
  ],

  // 始终以非 root 用户运行，避免生成的文件权限错乱
  "remoteUser": "vscode",

  // 容器创建完成后，自动同意所有 Android 许可协议
  "postCreateCommand": "yes | sdkmanager --licenses || true"
}
