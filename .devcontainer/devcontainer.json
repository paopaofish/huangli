{
    "name": "Android 14 Dev Container (Gradle 9)",
    // 使用功能丰富的通用基础镜像
    "image": "mcr.microsoft.com/devcontainers/universal:2-linux",
    
    // 安装 Java (Gradle 9 需要 Java 17 或更高) 和 Gradle 本身
    "features": {
        "ghcr.io/devcontainers/features/java:1": {
            "version": "17",
            "installMaven": false,
            "installGradle": true,
            "gradleVersion": "9.0"   // 明确指定 Gradle 9
        }
    },

    // 容器启动后执行的命令：安装 Android SDK 命令行工具、平台和构建工具
    "postCreateCommand": {
        // 1. 下载并解压 Android 命令行工具 (Linux 版)
        "download-sdk": "wget -q https://dl.google.com/android/repository/commandlinetools-linux-11076708_latest.zip -O /tmp/cmdline-tools.zip && unzip -q /tmp/cmdline-tools.zip -d /usr/local/ && mv /usr/local/cmdline-tools /usr/local/android-sdk && rm /tmp/cmdline-tools.zip",
        // 2. 设置环境变量 (临时) 并安装所需组件
        "install-sdk": "export ANDROID_HOME=/usr/local/android-sdk && export PATH=$PATH:$ANDROID_HOME/bin && yes | sdkmanager --licenses && sdkmanager 'platforms;android-34' 'build-tools;34.0.0'"
    },

    // 环境变量（在容器中持久生效）
    "containerEnv": {
        "ANDROID_HOME": "/usr/local/android-sdk",
        "PATH": "${containerEnv:PATH}:/usr/local/android-sdk/bin"
    },

    // VS Code 插件推荐
    "customizations": {
        "vscode": {
            "extensions": [
                "vscjava.vscode-java-pack",
                "google.android-code.Android-Studio-For-VSCode"
            ]
        }
    },

    // （可选）资源限制，默认足够
    "hostRequirements": {
        "cpus": 4,
        "memory": "8gb",
        "storage": "32gb"
    }
}
