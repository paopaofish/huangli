{
    "name": "Android Dev Container",
    "image": "mcr.microsoft.com/devcontainers/universal:2-linux", 
    "features": {
        "ghcr.io/devcontainers/features/java:1": {
            "version": "17",
            "installMaven": true,
            "installGradle": true
        }
    },
    "postCreateCommand": "sdkmanager 'platforms;android-33' 'build-tools;33.0.0'", 
    "customizations": {
        "vscode": {
            "extensions": [
                "vscjava.vscode-java-pack",
                "google.android-code.Android-Studio-For-VSCode" 
            ]
        }
    }
}
